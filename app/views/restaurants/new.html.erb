<h1>HI new</h1>
<div class="container">
  <h1>Add a restaurant</h1>
  <%= simple_form_for @restaurant do |f| %>
    <%= f.input :name %>
    <%= f.input :address %>
    <%= f.input :phone_number %>
    <%= f.input :category, collection: (Restaurant::CATEGORY) %>

    <%= f.button :submit , class: 'btn btn-secondary' %>
  <% end %>
</div>
<%= link_to restaurants_path, class: 'text-dark text-decoration-none' do %>
      <i class="fa-solid fa-backward btn btn-secondary"></i>
    <% end %>