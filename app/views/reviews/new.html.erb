<h1>HI new from review</h1>
<div class="container">
  <h1>Leave a review</h1>
  <%= simple_form_for [@restaurant, @review] do |f| %>
    <%= f.input :content %>
    <%= f.input :rating, collection: (0..5) %>

    <%= f.button :submit , class: 'btn btn-secondary' %>
  <% end %>
</div>
<%= link_to restaurants_path, class: 'text-dark text-decoration-none' do %>
      <i class="fa-solid fa-backward btn btn-secondary"></i>
    <% end %>